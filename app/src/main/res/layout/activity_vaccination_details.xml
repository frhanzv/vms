<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/activity_card_details_my_kad_bg"
    android:orientation="vertical"
    android:paddingTop="@dimen/_12sdp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginStart="@dimen/_18sdp"
        android:layout_marginEnd="@dimen/_18sdp"
        android:orientation="horizontal">


        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/_35sdp"
            android:layout_height="@dimen/_35sdp"
            android:src="@drawable/activity_card_details_my_kad_ic_back" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:text="Vaccination Details"
            android:textColor="#22306d"
            android:textSize="@dimen/text_size_lg"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_marginEnd="@dimen/_8sdp"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/cvCard"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_120sdp"
                android:layout_gravity="center_horizontal"
                android:layout_margin="@dimen/_10sdp"
                app:cardCornerRadius="@dimen/_20sdp"
                app:cardElevation="@dimen/_10sdp"
                app:cardPreventCornerOverlap="true">

                <ImageView
                    android:id="@+id/ivCard"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal">

                <TextView
                    android:id="@+id/tvUploadPhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Photo"
                    android:background="@drawable/btn_bg_blue"
                    android:textColor="@color/white"
                    android:padding="@dimen/_5sdp"
                    android:layout_margin="@dimen/_5sdp"/>

                <TextView
                    android:id="@+id/tvCaptrure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Capture Photo"
                    android:layout_margin="@dimen/_5sdp"
                    android:background="@drawable/btn_bg_blue"
                    android:textColor="@color/white"
                    android:padding="@dimen/_5sdp"/>


            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_10sdp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/_20sdp"
                app:cardElevation="@dimen/_10sdp"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_lg">

                    <!--Covid-19 Risk Status-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/white"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Covid-19 Risk Status"
                            android:textColor="#C8CCDD"
                            android:textSize="@dimen/text_size_sm" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/_15sdp"
                                android:layout_height="@dimen/_15sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_card_holder_name" />

                            <EditText
                                android:id="@+id/etCovid19RiskStatus"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/_35sdp"
                                android:layout_marginStart="@dimen/_8sdp"
                                android:background="@android:color/transparent"
                                android:gravity="center_vertical"
                                android:inputType="textPersonName"
                                android:textColor="#22306d"
                                android:textSize="@dimen/text_size_md" />

                        </LinearLayout>


                    </LinearLayout>
                    <View
                        android:id="@+id/viewCardHolderName"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="#F4F4F4" />

                    <!--Plks Expiry-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_20sdp"
                        android:background="@color/white"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Are you fully vaccinated?"
                            android:textColor="#C8CCDD"
                            android:textSize="@dimen/text_size_sm" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/_15sdp"
                                android:layout_height="@dimen/_15sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_address" />

                            <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
                                android:id="@+id/spFullyVaccinated"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/_35sdp"
                                android:layout_marginStart="@dimen/_8sdp"
                                android:background="@color/white"
                                app:smsp_enableFloatingLabel="false"
                                app:smsp_floatingLabelText=""
                                app:smsp_hint=""
                                app:smsp_itemColor="#512DA8"
                                app:smsp_itemListColor="#7C4DFF"
                                app:smsp_itemSize="@dimen/text_size_md"
                                app:smsp_multilineError="false"
                                app:smsp_selectedItemListColor="#22306d"
                                app:smsp_underlineColor="@color/white"/>

                        </LinearLayout>


                    </LinearLayout>
                    <View
                        android:id="@+id/viewPlksExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="#F4F4F4" />

                </LinearLayout>


            </androidx.cardview.widget.CardView>

            <RelativeLayout
                android:id="@+id/rlNext"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_45sdp"
                android:layout_margin="@dimen/_10sdp"
                android:background="@drawable/activity_card_details_my_kad_bg_next_btn">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/_20sdp"
                    android:text="Next"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_md"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_25sdp"
                    android:layout_height="@dimen/_25sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_20sdp"
                    android:src="@drawable/activity_card_details_my_kad_ic_next_btn_right_icon" />

            </RelativeLayout>

        </LinearLayout>
    </ScrollView>


</LinearLayout>