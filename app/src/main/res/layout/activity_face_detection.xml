<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_wo_logo_2">

    <!-- ✅ Camera preview — smaller, centered -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cameraCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/tvPlaceYourMyKad"
        app:layout_constraintBottom_toTopOf="@id/llBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.75"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintVertical_bias="0.5">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter"/>

        <com.safeg.facedetection.GraphicOverlay
            android:id="@+id/graphic_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </androidx.cardview.widget.CardView>

    <!-- ✅ Corner bracket frame -->
    <View
        android:id="@+id/faceScanFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/face_scan_frame"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="@id/cameraCard"
        app:layout_constraintBottom_toBottomOf="@id/cameraCard"
        app:layout_constraintStart_toStartOf="@id/cameraCard"
        app:layout_constraintEnd_toEndOf="@id/cameraCard"/>

    <!-- ✅ Title -->
    <TextView
        android:id="@+id/tvPlaceYourMyKad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="16dp"
        android:text="IDENTITY VERIFICATION"
        android:textColor="@color/white"
        android:textSize="23sp"
        android:textStyle="bold"
        android:fontFamily="@font/montserrat_bold"
        android:gravity="center"
        android:elevation="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ✅ Bottom section -->
    <LinearLayout
        android:id="@+id/llBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#00000000"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ✅ Look at camera instruction -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:src="@drawable/ic_person_24"
                android:background="@drawable/bg_success_badge"
                android:padding="10dp"
                android:layout_marginEnd="14dp"
                android:contentDescription="Person"
                app:tint="#006948"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PLEASE LOOK DIRECTLY AT CAMERA"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/montserrat_bold"/>

        </LinearLayout>

        <!-- ✅ Status card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_status_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="LIVENESS SENSOR IS ONLINE"
                android:textColor="#065F46"
                android:textSize="21sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="@font/montserrat_bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvCustomProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PLEASE BLINK TO ACTIVATE SENSOR"
                android:textColor="#047857"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="@font/montserrat_bold"/>

        </LinearLayout>

        <!-- ✅ Verifying button -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_45sdp"
            android:background="@drawable/white_roundedcorner"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvDetectionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="VERIFYING..."
                android:textColor="@color/colorPrimary"
                android:textSize="25sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="@font/montserrat_bold"/>

        </RelativeLayout>

        <!-- ✅ Progress bar hidden -->
        <ProgressBar
            android:id="@+id/customProgress"
            style="@style/CustomProgressBar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_7sdp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ✅ Back button -->
    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="@dimen/_24sdp"
        android:layout_height="@dimen/_24sdp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:elevation="50dp"
        android:src="@drawable/back_btn"
        android:contentDescription="Back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Hidden for code compatibility -->
    <androidx.cardview.widget.CardView
        android:id="@+id/preview_img_card"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:cardBackgroundColor="#00000000">
        <ImageView
            android:id="@+id/preview_img"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone"/>
    </androidx.cardview.widget.CardView>

    <ImageButton android:id="@+id/add_btn" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
    <ImageButton android:id="@+id/clear_btn" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
    <ImageButton android:id="@+id/switch_camera" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>

    <RelativeLayout
        android:id="@+id/centerView"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageView android:id="@+id/ivDots1" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivDots2" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivDots3" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivDots4" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivDots5" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivDots6" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivDots7" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivDots8" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
        <ImageView android:id="@+id/ivDots9" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone"/>
    </RelativeLayout>

    <View android:id="@+id/leftOverlay" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <View android:id="@+id/rightOverlay" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <LinearLayout android:id="@+id/llTop" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <View android:id="@+id/vTop" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>
    <View android:id="@+id/llPositionMyKadScanMyKad" android:layout_width="1dp" android:layout_height="1dp" android:visibility="gone" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>