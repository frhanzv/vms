<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:weightSum="2"
    tools:context=".activities.SelectOptionActivity"
    android:background="@drawable/bg2">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8">

        <ImageView
            android:layout_width="@dimen/_130sdp"
            android:layout_height="@dimen/_80sdp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="@dimen/_24sdp"
            android:layout_marginTop="@dimen/_2sdp"
            android:src="@drawable/ic_launcher"
            android:visibility="gone"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:gravity="bottom|center_horizontal"
            android:paddingTop="@dimen/_42sdp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:text="Welcome To"
                android:textColor="@color/black"
                android:textSize="@dimen/text_size_md" />

        </RelativeLayout>

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <View
                android:layout_width="@dimen/_5sdp"
                android:layout_height="@dimen/_1sdp"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/_5sdp" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="3dp"
                android:src="@drawable/ksbpic" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="5dp"
                android:src="@drawable/epic" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/_10sdp"
                android:gravity="center"
                android:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit ut aliquam, purus sit amet"
                android:textColor="#C8CCDD"
                android:textSize="@dimen/text_size_sm"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/llBegin"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_140sdp"
            android:layout_alignParentBottom="true"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="29dp"
            android:gravity="center"
            android:orientation="vertical">

            <!-- ✅ Invitation button — hidden by default, shown by applyFeatureFlags() -->
            <RelativeLayout
                android:id="@+id/rlMalaysianPr"
                android:layout_width="@dimen/_230sdp"
                android:layout_height="@dimen/_40sdp"
                android:background="@drawable/rounded_bg_white"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/_20sdp"
                    android:src="@drawable/ic_insert_invitation_24"
                    app:tint="@color/textColorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/_60sdp"
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Invitation"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="@dimen/text_size_md"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_28sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_20sdp"
                    android:src="@drawable/ic_arrow_forward_24"
                    app:tint="@color/textColorPrimary" />

            </RelativeLayout>

            <!-- ✅ Walk In button — hidden by default, shown by applyFeatureFlags() -->
            <RelativeLayout
                android:id="@+id/rlForeigner"
                android:layout_width="@dimen/_230sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginTop="@dimen/_7sdp"
                android:background="@drawable/rounded_bg"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/_20sdp"
                    android:src="@drawable/ic_insert_invitation_24"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/_60sdp"
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Walk In"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_md"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_28sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_20sdp"
                    android:src="@drawable/ic_arrow_forward_24"
                    app:tint="@color/white" />

            </RelativeLayout>

            <!-- ✅ Collect Card button — hidden by default, shown by applyFeatureFlags() -->
            <RelativeLayout
                android:id="@+id/rlCollect"
                android:layout_width="@dimen/_230sdp"
                android:layout_height="@dimen/_40sdp"
                android:layout_marginTop="@dimen/_7sdp"
                android:background="@drawable/rounded_bg_white"
                android:visibility="gone">

                <ImageView
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/_20sdp"
                    android:src="@drawable/ic_insert_invitation_24"
                    app:tint="@color/textColorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/_60sdp"
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Collect Card"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="@dimen/text_size_md"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_28sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_20sdp"
                    android:src="@drawable/ic_arrow_forward_24"
                    app:tint="@color/textColorPrimary" />

            </RelativeLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_above="@id/llBegin"
            android:layout_centerHorizontal="true"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/_10sdp"
                android:text="------------------   "
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_xsm" />

            <TextView
                android:id="@+id/ipSet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Option"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_xsm"
                android:fontFamily="@font/montserrat_regular"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingEnd="@dimen/_10sdp"
                android:text="   ------------------"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_xsm" />

        </LinearLayout>

    </RelativeLayout>

</LinearLayout>