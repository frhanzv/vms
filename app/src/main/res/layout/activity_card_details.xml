                        <View android:id="@+id/viewResident" android:layout_width="match_parent" android:layout_height="@dimen/_1sdp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/llGender" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gender" android:textColor="#888888" android:textSize="@dimen/_8ssp" android:fontFamily="@font/montserrat_bold"/>
                        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner android:id="@+id/spGender" android:layout_width="match_parent" android:layout_height="@dimen/_25sdp" android:background="@android:color/transparent" android:fontFamily="@font/montserrat_medium" app:smsp_enableFloatingLabel="false" app:smsp_hint="" app:smsp_itemColor="#111827" app:smsp_itemListColor="@color/colorPrimary" app:smsp_itemSize="@dimen/text_size_xsm" app:smsp_multilineError="false" app:smsp_selectedItemListColor="@color/colorPrimary" app:smsp_underlineColor="@android:color/transparent"/>
                        <View android:id="@+id/viewGender" android:layout_width="match_parent" android:layout_height="@dimen/_1sdp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/llVinCat" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vehicle Category" android:textColor="#888888" android:textSize="@dimen/_8ssp" android:fontFamily="@font/montserrat_bold"/>
                        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner android:id="@+id/spVinCat" android:layout_width="match_parent" android:layout_height="@dimen/_25sdp" android:background="@android:color/transparent" android:fontFamily="@font/montserrat_medium" app:smsp_enableFloatingLabel="false" app:smsp_hint="" app:smsp_itemColor="#111827" app:smsp_itemListColor="@color/colorPrimary" app:smsp_itemSize="@dimen/text_size_xsm" app:smsp_multilineError="false" app:smsp_selectedItemListColor="@color/colorPrimary" app:smsp_underlineColor="@android:color/transparent"/>
                        <View android:id="@+id/viewVinCat" android:layout_width="match_parent" android:layout_height="@dimen/_1sdp"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/llVinType" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="gone">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vehicle Type" android:textColor="#888888" android:textSize="@dimen/_8ssp" android:fontFamily="@font/montserrat_bold"/>
                        <com.chivorn.smartmaterialspinner.SmartMaterialSpinner android:id="@+id/spVinType" android:layout_width="match_parent" android:layout_height="@dimen/_25sdp" android:background="@android:color/transparent" android:fontFamily="@font/montserrat_medium" app:smsp_enableFloatingLabel="false" app:smsp_hint="" app:smsp_itemColor="#111827" app:smsp_itemListColor="@color/colorPrimary" app:smsp_itemSize="@dimen/text_size_xsm" app:smsp_multilineError="false" app:smsp_selectedItemListColor="@color/colorPrimary" app:smsp_underlineColor="@android:color/transparent"/>
                        <View android:id="@+id/viewVinType" android:layout_width="match_parent" android:layout_height="@dimen/_1sdp"/>
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Next button -->
            <RelativeLayout
                android:id="@+id/rlNext"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_45sdp"
                android:layout_marginHorizontal="@dimen/_10sdp"
                android:layout_marginVertical="@dimen/_10sdp"
                android:background="@drawable/btn_primary_bg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/_20sdp"
                    android:fontFamily="@font/montserrat_bold"
                    android:text="Next"
                    android:textColor="@color/colorPrimary"
                    android:textSize="@dimen/text_size_md"/>

                <ImageView
                    android:layout_width="@dimen/_18sdp"
                    android:layout_height="@dimen/_18sdp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="@dimen/_20sdp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/arrow"
                    app:tint="@color/colorPrimary"/>

            </RelativeLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>