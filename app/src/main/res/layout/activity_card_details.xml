<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_wo_logo_2"
    android:orientation="vertical"
    android:paddingTop="@dimen/_12sdp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginStart="@dimen/_18sdp"
        android:layout_marginEnd="@dimen/_18sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:src="@drawable/back_btn"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:text="MyKad Details"
            android:textColor="@color/white"
            android:textSize="@dimen/text_size_md"
            android:textStyle="bold"
            android:padding="@dimen/_6sdp"
            android:fontFamily="@font/montserrat_bold"
            android:background="@drawable/bg_glassy_translucent"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <ImageView
            android:id="@+id/logoRight"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:src="@drawable/mnr_logo_removebg"
            android:contentDescription="Logo"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_18sdp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/dottedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_10sdp"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_dashed_border_white">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_90sdp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvCard"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="@dimen/_12sdp"
                        app:cardPreventCornerOverlap="true"
                        app:cardBackgroundColor="#80ffffff">

                        <ImageView
                            android:id="@+id/ivCard"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone"/>

                        <LinearLayout
                            android:id="@+id/llCardPlaceholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="@dimen/_30sdp"
                                android:layout_height="@dimen/_30sdp"
                                app:tint="@android:color/white"/>
                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvScanKad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan MyKad"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="@dimen/_12ssp"
                        android:fontFamily="@font/montserrat_bold"
                        android:background="@drawable/bg_button_bluish"
                        android:paddingHorizontal="@dimen/_20sdp"
                        android:paddingVertical="@dimen/_7sdp"
                        android:layout_gravity="center"
                        android:elevation="20dp"/>

                </FrameLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/_6sdp">

                <TextView
                    android:id="@+id/tvUploadPhoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Photo"
                    android:background="@drawable/bg_solid_white_rounded"
                    android:textColor="@color/white"
                    android:fontFamily="@font/montserrat_medium"
                    android:visibility="gone"
                    android:padding="@dimen/_5sdp"
                    android:layout_margin="@dimen/_5sdp"/>

                <TextView
                    android:id="@+id/tvCaptrure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Capture Photo"
                    android:layout_margin="@dimen/_5sdp"
                    android:background="@drawable/bg_solid_white_rounded"
                    android:textColor="@color/white"
                    android:fontFamily="@font/montserrat_medium"
                    android:visibility="gone"
                    android:padding="@dimen/_5sdp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/_10sdp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="@dimen/_12sdp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_12sdp">

                    <!-- ✅ Contact Number -->
                    <LinearLayout
                        android:id="@+id/llContactNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CONTACT NUMBER"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_contact_number"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <EditText
                                android:id="@+id/etContactNumber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:inputType="number"
                                android:textColor="#111827"
                                android:textSize="@dimen/text_size_xsm"
                                android:fontFamily="@font/montserrat_medium"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View android:id="@+id/viewContactNumber" android:layout_width="match_parent" android:layout_height="0dp"/>

                    <!-- ✅ Company Name -->
                    <LinearLayout
                        android:id="@+id/llCompanyName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMPANY NAME"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_company_name"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <EditText
                                android:id="@+id/etCompanyName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:imeOptions="actionNext"
                                android:inputType="textCapCharacters"
                                android:textColor="#111827"
                                android:textSize="@dimen/text_size_xsm"
                                android:fontFamily="@font/montserrat_medium"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View android:id="@+id/viewCompanyName" android:layout_width="match_parent" android:layout_height="0dp"/>

                    <!-- ✅ Email -->
                    <LinearLayout
                        android:id="@+id/llEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMAIL"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_email"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <EditText
                                android:id="@+id/etEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:inputType="textEmailAddress"
                                android:textColor="#111827"
                                android:textSize="@dimen/text_size_xsm"
                                android:fontFamily="@font/montserrat_medium"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View android:id="@+id/viewEmail" android:layout_width="match_parent" android:layout_height="0dp"/>

                    <!-- Vehicle Reg No -->
                    <LinearLayout
                        android:id="@+id/llRegNo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VEHICLE REGISTRATION NO"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_contact_number"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <EditText
                                android:id="@+id/etRegNo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:imeOptions="actionNext"
                                android:inputType="textCapCharacters"
                                android:textColor="#111827"
                                android:textSize="@dimen/text_size_xsm"
                                android:fontFamily="@font/montserrat_medium"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View android:id="@+id/viewRegNo" android:layout_width="match_parent" android:layout_height="0dp"/>

                    <!-- Cardholder Name -->
                    <LinearLayout
                        android:id="@+id/llCardholderName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CARDHOLDER NAME"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_card_holder_name"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <EditText
                                android:id="@+id/etCardHolderName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:inputType="textPersonName"
                                android:textColor="#111827"
                                android:textSize="@dimen/text_size_xsm"
                                android:fontFamily="@font/montserrat_medium"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View android:id="@+id/viewCardHolderName" android:layout_width="match_parent" android:layout_height="0dp"/>
                    <!-- IC Number -->
                    <LinearLayout
                        android:id="@+id/llIc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvIcNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IC NUMBER"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@android:drawable/ic_dialog_dialer"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <EditText
                                android:id="@+id/etCardNumber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:textColor="#111827"
                                android:textSize="@dimen/text_size_xsm"
                                android:fontFamily="@font/montserrat_medium"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Address -->
                    <LinearLayout
                        android:id="@+id/llAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADDRESS"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input_field"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:paddingTop="@dimen/_8sdp"
                            android:paddingBottom="@dimen/_8sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:layout_gravity="top"
                                android:layout_marginTop="@dimen/_2sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_address"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <EditText
                                android:id="@+id/etAddress"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/_30sdp"
                                android:background="@android:color/transparent"
                                android:inputType="textMultiLine"
                                android:maxLines="3"
                                android:gravity="top|start"
                                android:singleLine="false"
                                android:textColor="#111827"
                                android:textSize="@dimen/text_size_xsm"
                                android:fontFamily="@font/montserrat_medium"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View android:id="@+id/viewAddress" android:layout_width="match_parent" android:layout_height="0dp"/>

                    <!-- Date of Birth -->
                    <LinearLayout
                        android:id="@+id/llDateOfBirth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDateOfBirthTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DATE OF BIRTH"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:id="@+id/ivDateOfBirth"
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_address"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <TextView
                                android:id="@+id/tvDateOfBirth"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:textColor="#111827"
                                android:textSize="@dimen/text_size_xsm"
                                android:fontFamily="@font/montserrat_medium"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View android:id="@+id/viewDateOfBirth" android:layout_width="match_parent" android:layout_height="0dp"/>

                    <!-- PLKS Expiry -->
                    <LinearLayout
                        android:id="@+id/llPlksExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">
                        <TextView android:id="@+id/tvPlksExpiryTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PLKS Expiry" android:textColor="#888888" android:textSize="@dimen/_8ssp" android:fontFamily="@font/montserrat_bold"/>
                        <TextView android:id="@+id/tvPlksExpiry" android:layout_width="match_parent" android:layout_height="@dimen/_10sdp" android:textColor="#111827" android:textSize="@dimen/text_size_xsm" android:fontFamily="@font/montserrat_medium"/>
                        <ImageView android:id="@+id/ivPlksExpiry" android:layout_width="@dimen/_8sdp" android:layout_height="@dimen/_8sdp" android:src="@drawable/activity_card_details_my_kad_ic_address"/>
                    </LinearLayout>

                    <!-- Country -->
                    <LinearLayout
                        android:id="@+id/llCountry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COUNTRY"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_address"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
                                android:id="@+id/spCountry"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:fontFamily="@font/montserrat_bold"
                                android:textStyle="bold"
                                app:smsp_searchHeaderText="Select country"
                                app:smsp_isSearchable="true"
                                app:smsp_enableFloatingLabel="false"
                                app:smsp_hint="Select Country"
                                app:smsp_hintColor="@android:color/transparent"
                                app:smsp_itemColor="#111827"
                                app:smsp_itemListColor="@color/colorPrimary"
                                app:smsp_itemSize="@dimen/text_size_xsm"
                                app:smsp_multilineError="false"
                                app:smsp_selectedItemListColor="@color/colorPrimary"
                                app:smsp_arrowColor="@color/colorPrimary"
                                app:smsp_underlineColor="@android:color/transparent"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- State -->
                    <LinearLayout
                        android:id="@+id/llState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATE"
                            android:textColor="#888888"
                            android:textSize="@dimen/_8ssp"
                            android:fontFamily="@font/montserrat_bold"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="@dimen/_4sdp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_40sdp"
                            android:background="@drawable/bg_input_field"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/_10sdp"
                            android:paddingEnd="@dimen/_10sdp"
                            android:layout_marginBottom="@dimen/_10sdp">

                            <ImageView
                                android:layout_width="@dimen/_14sdp"
                                android:layout_height="@dimen/_14sdp"
                                android:src="@drawable/activity_card_details_my_kad_ic_address"
                                android:layout_marginEnd="@dimen/_8sdp"
                                app:tint="@color/colorPrimary"/>

                            <com.chivorn.smartmaterialspinner.SmartMaterialSpinner
                                android:id="@+id/spState"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:fontFamily="@font/montserrat_bold"
                                android:textStyle="bold"
                                app:smsp_enableFloatingLabel="false"
                                app:smsp_hint=""
                                app:smsp_hintColor="@android:color/transparent"
                                app:smsp_searchHeaderText="Select state"
                                app:smsp_isSearchable="true"
                                app:smsp_itemColor="#111827"
                                app:smsp_itemListColor="@color/colorPrimary"
                                app:smsp_itemSize="@dimen/text_size_xsm"
                                app:smsp_multilineError="false"
                                app:smsp_selectedItemListColor="@color/colorPrimary"
