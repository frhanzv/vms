<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- smooth blue gradient like the one in your image -->
    <gradient
        android:startColor="#4A64F1"
        android:endColor="#2C3EB8"
        android:angle="90"/>
    <corners android:radius="12dp"/>
    <padding
        android:left="16dp"
        android:right="16dp"
        android:top="6dp"
        android:bottom="6dp" />
    <stroke
        android:width="1dp"
        android:color="#8090C5F6" />
</shape>
