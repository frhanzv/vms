<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@android:id/background">
        <shape>
            <corners
                android:radius="5dip" />
            <gradient
                android:startColor="#2D22306D"
                android:centerColor="#2D22306D"
                android:centerY="0.50"
                android:endColor="#2D22306D"
                android:angle="270" />
        </shape>
    </item>
    <item
        android:id="@android:id/progress">
        <clip>
            <shape>
                <corners
                    android:radius="5dip" />
                <gradient
                    android:startColor="#1DBEE9"
                    android:endColor="#1DBEE9"
                    android:angle="90" />
            </shape>
        </clip>
    </item>
</layer-list>